{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-wps.local/schemas/writing-policy-pack-v1.json",
  "title": "AI-WPS Writing Policy Pack v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packId",
    "version",
    "name",
    "sceneIds",
    "source",
    "review",
    "entries"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "packId": { "type": "string", "pattern": "^[a-z][a-z0-9.-]{2,63}$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "sceneIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["yangqi", "cybersecurity", "official"] }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "commit", "license"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "version": { "type": "string", "minLength": 1, "maxLength": 80 },
        "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "license": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewedAt", "reviewedBy", "manifest"],
      "properties": {
        "reviewedAt": { "type": "string", "format": "date" },
        "reviewedBy": { "type": "string", "minLength": 1, "maxLength": 120 },
        "manifest": { "type": "string", "pattern": "^[^/\\\\]+\\.review\\.json$" }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/term" },
          { "$ref": "#/$defs/rule" }
        ]
      }
    }
  },
  "$defs": {
    "common": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^(term|rule)\\.[a-z0-9][a-z0-9.-]{2,95}$" },
        "category": { "type": "string", "minLength": 1, "maxLength": 80 },
        "priority": { "type": "integer", "minimum": 0, "maximum": 100 },
        "defaultEnabled": { "type": "boolean" },
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 300 }
        }
      }
    },
    "term": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "type",
            "category",
            "preferredText",
            "aliases",
            "forbiddenVariants",
            "definition",
            "contextKeywords",
            "priority",
            "defaultEnabled",
            "sourceRefs"
          ],
          "properties": {
            "id": { "type": "string" },
            "type": { "const": "term" },
            "category": { "type": "string" },
            "preferredText": { "type": "string", "minLength": 1, "maxLength": 200 },
            "aliases": { "type": "array", "uniqueItems": true, "items": { "type": "string", "maxLength": 200 } },
            "forbiddenVariants": { "type": "array", "uniqueItems": true, "items": { "type": "string", "maxLength": 200 } },
            "definition": { "type": "string", "minLength": 1, "maxLength": 600 },
            "contextKeywords": { "type": "array", "uniqueItems": true, "items": { "type": "string", "maxLength": 200 } },
            "priority": { "type": "integer" },
            "defaultEnabled": { "type": "boolean" },
            "sourceRefs": { "type": "array" }
          }
        }
      ]
    },
    "rule": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "type",
            "category",
            "name",
            "ruleText",
            "positiveExample",
            "negativeExample",
            "taskTypes",
            "sceneIds",
            "contextKeywords",
            "priority",
            "defaultEnabled",
            "sourceRefs"
          ],
          "properties": {
            "id": { "type": "string" },
            "type": { "enum": ["style", "anti_template"] },
            "category": { "type": "string" },
            "name": { "type": "string", "minLength": 1, "maxLength": 160 },
            "ruleText": { "type": "string", "minLength": 1, "maxLength": 1000 },
            "positiveExample": { "type": "string", "maxLength": 600 },
            "negativeExample": { "type": "string", "maxLength": 600 },
            "taskTypes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "enum": ["smart_write", "smart_imitate", "document_review"] }
            },
            "sceneIds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "enum": ["yangqi", "cybersecurity", "official"] }
            },
            "contextKeywords": { "type": "array", "uniqueItems": true, "items": { "type": "string", "maxLength": 200 } },
            "priority": { "type": "integer" },
            "defaultEnabled": { "type": "boolean" },
            "sourceRefs": { "type": "array" }
          }
        }
      ]
    }
  }
}
